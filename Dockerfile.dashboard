# Sentinel dashboard — Next.js, buildable from the repo ROOT.
#
# Use this Dockerfile when Railway (or another platform) builds from the
# repo root and you can't easily set a Root Directory. It only COPYs
# dashboard/* paths, ignoring the rest of the repo, so the Python
# gateway source is never pulled into the dashboard image.
#
# Railway config: gateway service uses ./Dockerfile (default), dashboard
# service uses Build → Dockerfile Path = `Dockerfile.dashboard`.

FROM node:20-alpine AS deps
WORKDIR /app
COPY dashboard/package.json dashboard/package-lock.json* ./
RUN npm ci

FROM node:20-alpine AS builder
ARG NEXT_PUBLIC_SENTINEL_URL=http://127.0.0.1:8088
ENV NEXT_PUBLIC_SENTINEL_URL=${NEXT_PUBLIC_SENTINEL_URL}
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY dashboard/ ./
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["sh", "-c", "npx next start -p ${PORT:-3000}"]
