# Gemini API — without this, the Flash gate falls back to a deterministic
# heuristic and PolicyPipe ingestion is disabled. The demo loop still runs.
GEMINI_API_KEY=

# Postgres (audit ledger, cost meter, policy_docs)
DATABASE_URL=postgresql://sankar@localhost:5432/agent_sentinel

# Sentinel core
SENTINEL_JWT_SIGNING_KEY=generate-a-64-char-hex-string-here
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8088
